# WhaleWatch/TickerTape — Privacy-first .gitignore
# Purpose: prevent local research artifacts, secrets, and scratch files from being committed

# Virtual environments
venv/
.venv/
env/
*.env
.env.local

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime / generated data
data/
outputs/
*.parquet
*.ndjson

# Data caches and research artifacts (local-only)
local_cache/
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pickle
*.json
*.db
*.sqlite
*.sqlite3
*.h5
*.arrow
.cache/
cache/
tmp/

# Backtest and Monte Carlo outputs
backtest_*
bt_*
mc_*
mc_outputs/
bt_outputs/

# Local logs and profiling output
logs/
*.log
*.trace
*.profile

# Secrets and key material
HLdontShare.env
LOCAL_SECRETS_SETUP.md
secrets/
.tickertape/
*.key
*.pem
*.crt
*.secret
*.override

# Editor / OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak
.vscode/
.idea/
*.code-workspace

# Private scratch directories
../dontShare/
../dontShareCB.py

# Explicitly DO NOT ignore canonical project files (Vision, docs, playbooks, tests)
!BtheVision_v1_5_5.txt
!FtheVision_v1_5_5.txt
!README.md
!PRD.md
!COMMAND_CHEATSHEET.md
!STRATEGY_IMPLEMENTATION_GUIDE.md
!LICENSE_NOTICE.md
!docs/
!playbooks/
!tests/
!tools/

# Note: If secrets are found in the repository history, rotate them and remove them from history using
# tools such as `git filter-repo` or the BFG Repo-Cleaner. This directory-level .gitignore favors safety over convenience.