# WhaleWatch/TickerTape — Privacy-first .gitignore
# Purpose: prevent local research artifacts, secrets, and scratch files from being committed

# Virtual environments
algo/
TickerTape/
venv/
.venv/
env/
TickerTape/
*.env
.env.local

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime / generated data
data/
outputs/
*.parquet
*.ndjson

# Data caches and research artifacts (local-only)
local_cache/
*.ndjson
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pickle
*.json
*.db
*.sqlite
*.sqlite3
*.h5
*.arrow
.cache/
cache/
tmp/
data/

# Backtest and Monte Carlo outputs
backtest_*
bt_*
mc_*
mc_outputs/
bt_outputs/

# Local logs and profiling output
logs/
*.log
*.trace
*.profile

# Secrets and key material
HLdontShare.env
LOCAL_SECRETS_SETUP.md
secrets/
.tickertape/
*.key
*.pem
*.crt
*.secret
*.override

# Editor / OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak
.vscode/
.idea/
*.code-workspace

# Private scratch directories
../dontShare/
../dontShareCB.py

# Private input material (vault notes, handoff packages) — never publish
filesFromFable/
filesFromFable.zip

# Internal planning material — local working docs, never publish
PROMPT_*.md
IMPLEMENTATION_PLAN.md
PRD.md
AGENTS.md
bTest_MC_logic.md
*theVision*.txt
docs/REQUIREMENT_TRACE.md
docs/PR_DRAFT.md
specs/
playbooks/

# Bot runtime surfaces (local state, append-only signal tape)
signals/
state/

# Explicitly DO NOT ignore canonical project files (docs, tests, tools)
# (Vision/PRD/playbooks negations removed 2026-06-11: internal planning
#  material stays local-only now that the repo is public.)
!README.md
!COMMAND_CHEATSHEET.md
!STRATEGY_IMPLEMENTATION_GUIDE.md
!LICENSE_NOTICE.md
!docs/
!tests/
!tools/

# Note: If secrets are found in the repository history, rotate them and remove them from history using
# tools such as `git filter-repo` or the BFG Repo-Cleaner. This directory-level .gitignore favors safety over convenience.

# Copilot role prompts — internal, local-only
.github/prompts/
