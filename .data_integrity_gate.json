{
  "scan_roots": ["src", "tests", "docs"],
  "default_external_secrets_path": "~/.tickertape/secrets/HLdontShare.env",
  "required_gitignore_patterns": ["HLdontShare.env", "LOCAL_SECRETS_SETUP.md", ".tickertape/", "secrets/"],
  "required_files": ["requirements.txt"],
  "forbidden_files": ["HLdontShare.env"],
  "allowlist": [
    {
      "file": "tests/",
      "category": "synthetic_or_fake_data",
      "pattern_contains": "np\\.random",
      "reason": "Randomness allowed in tests only; must be seeded."
    },
    {
      "file": "PRD.md",
      "category": "synthetic_or_fake_data",
      "pattern_contains": "synthetic data",
      "reason": "Documentation policy wording; not executable code."
    }


  ]
}